{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GMFeather",
  "version": "0.1.0",
  "identifier": "com.gmfeather.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GMFeather",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/logo.png",
      "icons/logo.ico"
    ],
    "resources": [
      "../target/release/gmfeather*"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "installer.nsh",
        "installMode": "currentUser"
      }
    }
  }
}